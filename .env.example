OPENAI_API_KEY=
# Optional; default gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional; default text-embedding-3-small / 1536
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
# Optional logging controls. Development defaults to info; production defaults to warn.
# LOG_LEVEL=debug
# LOG_SCOPES=chat,rag
# NEXT_PUBLIC_LOG_LEVEL=debug
# NEXT_PUBLIC_LOG_SCOPES=chat
# Optional; Payload collections default to file:apps/portfolio/portfolio.db when omitted
# DATABASE_URL=file:./apps/portfolio/portfolio.db
# Optional; sqlite-vec / FTS sidecar index DB. Defaults to apps/portfolio/portfolio-rag.db
# RAG_SQLITE_PATH=./apps/portfolio/portfolio-rag.db
# Required before Payload-backed RAG or admin ingest can run safely
PAYLOAD_SECRET=
# Required for owner-only ingest/admin endpoints
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
# Set to 0 to hide the floating site chat (still requires OPENAI_API_KEY when enabled)
# NEXT_PUBLIC_SITE_CHAT=0
# RepoPlanner: monorepo root containing .planning/ + vendor/repo-planner (portfolio next.config sets this when unset)
# REPOPLANNER_PROJECT_ROOT=../..
# CLI usage + generated reports directory (default .planning-reports at monorepo root; keeps .planning/ free of reports/)
# REPOPLANNER_REPORTS_DIR=.planning-reports
# Embedded cockpit: allow POST /api/planning-edits/apply and POST /api/planning-cli/run (writes / spawns CLI). Default off.
# PLANNING_COCKPIT_ALLOW_SERVER_WRITES=1
# Listen page: JSON map of lock group slug -> shared password (httpOnly cookie after POST /api/listen/unlock)
# LISTEN_LOCK_GROUPS={"preview":"your-shared-secret"}
