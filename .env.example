OPENAI_API_KEY=
# Optional: cap how long the auth subprocess may block `/api/auth/session` (default 25000). Prevents infinite "Checking session" when DB is unreachable.
# AUTH_WORKER_TIMEOUT_MS=25000
# Show Site Copilot button without OPENAI_API_KEY (otherwise set when key exists, or use local/LAN host auto-detection in `app/layout.tsx`).
# NEXT_PUBLIC_SITE_CHAT_SHOW=1
# Optional; default dall-e-3. Site UI: POST /api/media/generate (admin session). CLI: `pnpm magicborn generate …` reads this from repo `.env` (no cookie).
# OPENAI_IMAGE_MODEL=dall-e-3
# Playwright only: full Cookie header for an owner/admin session (e.g. portfolio-token=...) for authenticated media E2E.
# E2E_OWNER_COOKIE=
# Optional; default gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional; default text-embedding-3-small / 1536
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
# Optional: attach org/project to API requests (OpenAI-Organization / OpenAI-Project headers). See platform docs.
# OPENAI_ORGANIZATION=org_...
# OPENAI_PROJECT=proj_...
# Optional: Organization Admin API key for `magicborn openai projects` only — not your default OPENAI_API_KEY.
# OPENAI_ADMIN_KEY=
# Linked Supabase project bootstrap
SUPABASE_PROJECT_REF=rqvahypyhisslcrkdokf
NEXT_PUBLIC_SUPABASE_URL=https://rqvahypyhisslcrkdokf.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_LGwEZKjyfJ7HDWHZ0CUYKw_zqW_ZAGQ
# Optional legacy key surfaces for scripts or one-off bootstrap helpers.
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# Optional logging controls. Development defaults to info; production defaults to warn.
# LOG_LEVEL=debug
# LOG_SCOPES=chat,rag
# Optional server file logs (JSON lines) with local rotation.
# LOG_FILE_ENABLED=1
# LOG_FILE_PATH=./.logs/portfolio-server.log
# LOG_FILE_MAX_BYTES=5242880
# LOG_FILE_MAX_FILES=5
# First POST /api/chat in this Node process: print full process.env (unredacted) to the server terminal and/or file.
# LOG_CHAT_RUNTIME_ENV=1
# Relative paths are resolved from apps/portfolio (not pnpm cwd). Absolute paths work as-is.
# LOG_CHAT_RUNTIME_ENV_FILE=./chat-runtime-env.log
# Set to 0 to disable RAG for site chat (no embedding API calls; system prompt + messages only).
# SITE_CHAT_RAG=0
# NEXT_PUBLIC_LOG_LEVEL=debug
# NEXT_PUBLIC_LOG_SCOPES=chat
# Payload database provider. Default local mode is sqlite.
PAYLOAD_DB_PROVIDER=postgres
# Optional in sqlite mode; defaults to apps/portfolio/portfolio.db when omitted.
# Relative sqlite paths are resolved from apps/portfolio, so `file:./portfolio.db` maps to apps/portfolio/portfolio.db.
# In postgres mode this must be a Postgres connection string, e.g. your Supabase pooled connection URL.
# Replace __SUPABASE_DB_PASSWORD__ with the database password from the Supabase dashboard.
# The session pooler is the safer default on Windows/IPv4-only machines and keeps the Payload seed flow working.
DATABASE_URL=postgresql://postgres.rqvahypyhisslcrkdokf:__SUPABASE_DB_PASSWORD__@aws-0-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true&connection_limit=1
# Optional direct host alternative if your machine has working IPv6 connectivity:
# DATABASE_URL=postgresql://postgres:__SUPABASE_DB_PASSWORD__@db.rqvahypyhisslcrkdokf.supabase.co:5432/postgres
# Optional sqlite-specific override when PAYLOAD_DB_PROVIDER=sqlite
# PAYLOAD_SQLITE_PATH=./portfolio.db
# Optional postgres helper; use 1 only when you intentionally want Payload to push schema changes.
PAYLOAD_POSTGRES_PUSH=0
# Payload upload storage provider. Default local mode writes to apps/portfolio/media/reader-library.
# Set to s3 to use Supabase Storage's S3-compatible endpoint for upload collections.
PAYLOAD_STORAGE_PROVIDER=s3
# Required when PAYLOAD_STORAGE_PROVIDER=s3.
# Create the S3 access-key pair in Supabase Storage Configuration; the private `reader-library` bucket is already expected.
PAYLOAD_S3_BUCKET=reader-library
PAYLOAD_S3_ENDPOINT=https://rqvahypyhisslcrkdokf.storage.supabase.co/storage/v1/s3
PAYLOAD_S3_REGION=us-west-2
PAYLOAD_S3_ACCESS_KEY_ID=__SUPABASE_S3_ACCESS_KEY_ID__
PAYLOAD_S3_SECRET_ACCESS_KEY=__SUPABASE_S3_SECRET_ACCESS_KEY__
# Required for Supabase S3 compatibility; keep true unless you know you need otherwise.
PAYLOAD_S3_FORCE_PATH_STYLE=true
# Optional books artifact publisher helpers.
# Set to 1 to auto-upload built EPUBs and planning-pack zips after `pnpm run build:books`.
# BOOK_ARTIFACTS_AUTO_PUBLISH=0
# Optional immutable checkpoint/version label. When omitted, the publisher uses `cp-YYYYMMDD-HHmmss-<gitsha>`.
# BOOK_ARTIFACT_VERSION=cp01
# Optional; sqlite-vec / FTS sidecar when RAG_VECTOR_STORE=sqlite. Relative paths resolve from apps/portfolio.
# Defaults to apps/portfolio/portfolio-rag.db
# RAG_SQLITE_PATH=./portfolio-rag.db
# Vector index: with Payload Postgres + DATABASE_URL, semantic search uses pgvector in the same Supabase DB (tables created on first ingest). Force the local sidecar with RAG_VECTOR_STORE=sqlite.
# RAG_VECTOR_STORE=sqlite
# Embeddings: default is local Xenova MiniLM (384-d) + cache under apps/portfolio/models/.transformers-cache/. Set RAG_EMBEDDING_PROVIDER=openai to use OPENAI_EMBEDDING_* (1536-d).
# Switching embeddings provider requires clearing the vector index (delete sidecar DB and/or rag_chunk_search rows) and re-running `pnpm rag:ingest`.
# RAG_EMBEDDING_PROVIDER=openai
# RAG_LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# RAG_LOCAL_EMBEDDING_DIMENSIONS=384
# Ingest parallelism (optional): parallel Payload rag-sources upserts and parallel checksum-reuse pipelines. Embedding stays one source at a time.
# RAG_INGEST_SOURCE_UPSERT_CONCURRENCY=8
# RAG_INGEST_REUSE_SOURCE_CONCURRENCY=4
# Full-run checksum reuse: bulk-copy rag_chunks via SQL (default on). Set 0 to force Payload creates only.
# RAG_INGEST_BULK_CHUNK_CLONE=0
#
# Postgres / Supabase: if ingest or Payload updates fail with missing column on payload_locked_documents_rels
# (e.g. project_records_id), run once from repo root:
#   pnpm --filter @portfolio/app run payload:fix-locks-rels
# Required before Payload-backed RAG or admin ingest can run safely
PAYLOAD_SECRET=
# Required for owner-only ingest/admin endpoints
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
# Set to 0 to hide the floating site chat (still requires OPENAI_API_KEY when enabled)
# NEXT_PUBLIC_SITE_CHAT=0
# RepoPlanner: monorepo root containing .planning/ + vendor/repo-planner (portfolio next.config sets this when unset)
# REPOPLANNER_PROJECT_ROOT=../..
# CLI usage + generated reports directory (default .planning-reports at monorepo root; keeps .planning/ free of reports/)
# REPOPLANNER_REPORTS_DIR=.planning-reports
# Embedded cockpit: allow POST /api/planning-edits/apply and POST /api/planning-cli/run (writes / spawns CLI). Default off.
# PLANNING_COCKPIT_ALLOW_SERVER_WRITES=1
# Listen page: JSON map of lock group slug -> shared password (httpOnly cookie after POST /api/listen/unlock)
# LISTEN_LOCK_GROUPS={"preview":"your-shared-secret"}
# RAG ingest resolves `apps/portfolio` automatically when you run `pnpm rag:ingest` from the repo root.
# Override only if you run ingest helpers from an unusual working directory:
# PORTFOLIO_APP_ROOT=
