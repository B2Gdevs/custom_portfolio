{
  "name": "@portfolio/repub-builder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Build RichEPub (.repub) from a repub project (Vite + React + Tailwind)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "repub-build": "./dist/cli.js",
    "repub": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MagicbornStudios/custom_portfolio.git",
    "directory": "packages/repub-builder"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "repub",
    "richepub",
    "epub",
    "ebook",
    "vite",
    "react"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.copyFileSync('src/reader.html','dist/reader.html'); fs.mkdirSync('dist/templates',{recursive:true}); fs.copyFileSync('src/templates/content.opf.ejs','dist/templates/content.opf.ejs');\"",
    "repub": "node dist/cli.js"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.0.0",
    "@portfolio/book-components": "workspace:*",
    "archiver": "^7.0.1",
    "epub-gen": "^0.1.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
