{
  "name": "@portfolio/app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-planning-pack.cjs && node scripts/build-planning-embed-packs.cjs && concurrently -n books,next -c green,cyan \"node scripts/watch-books-dev.cjs\" \"next dev --webpack\"",
    "build": "node scripts/build-planning-pack.cjs && node scripts/build-planning-embed-packs.cjs && next build --webpack",
    "planning:embed-packs": "node scripts/build-planning-embed-packs.cjs",
    "planning:embed-book-pack": "node scripts/build-book-planning-embed-pack.cjs",
    "build:epub": "node scripts/build-epub.cjs",
    "books:publish": "tsx --tsconfig tsconfig.json scripts/publish-book-artifacts.ts",
    "media:publish": "tsx --tsconfig tsconfig.json scripts/publish-public-media.ts",
    "site:publish:downloads": "tsx --tsconfig tsconfig.json scripts/publish-site-download-assets.ts",
    "provider:status": "tsx --tsconfig tsconfig.json scripts/provider-bootstrap.ts status",
    "provider:export:local": "tsx --tsconfig tsconfig.json scripts/provider-bootstrap.ts export-local",
    "provider:import:local": "tsx --tsconfig tsconfig.json scripts/provider-bootstrap.ts import-local",
    "provider:bootstrap:hosted": "tsx --tsconfig tsconfig.json scripts/provider-bootstrap.ts bootstrap-hosted",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:report": "node scripts/run-unit-report.mjs",
    "test:e2e": "playwright test",
    "test:e2e:reader": "playwright test -c playwright.reader.config.ts",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "rag:ingest": "node scripts/rag-ingest-runner.cjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:seed": "tsx --tsconfig tsconfig.json scripts/seed-auth-owner.ts",
    "auth:invite": "tsx --tsconfig tsconfig.json scripts/invite-user.ts",
    "auth:revoke-invite": "tsx --tsconfig tsconfig.json scripts/revoke-invite.ts",
    "auth:set-role": "tsx --tsconfig tsconfig.json scripts/set-user-role.ts",
    "auth:disable-user": "tsx --tsconfig tsconfig.json scripts/disable-user.ts",
    "listen:seed": "tsx --tsconfig tsconfig.json scripts/seed-listen-catalog.ts",
    "site:seed:apps": "tsx --tsconfig tsconfig.json scripts/seed-site-app-records.ts",
    "site:seed:projects": "tsx --tsconfig tsconfig.json scripts/seed-project-records.ts",
    "site:seed:resumes": "tsx --tsconfig tsconfig.json scripts/seed-resume-records.ts",
    "chat:env-preview": "tsx --tsconfig tsconfig.json scripts/chat-env-preview.ts",
    "payload:fix-locks-rels": "tsx --tsconfig tsconfig.json scripts/apply-payload-locks-rels-columns.ts",
    "payload:fix-public-records": "tsx --tsconfig tsconfig.json scripts/apply-payload-public-records-schema.ts"
  },
