{
  "name": "portfolio-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "bin": {
    "magicborn": "./packages/magicborn-cli/dist/cli.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages-shared/*",
    "vendor/repub-builder"
  ],
  "scripts": {
    "postinstall": "node scripts/magicborn-postinstall.cjs",
    "setup": "./scripts/setup-git-hooks.sh",
    "dev": "npm run dev --workspace=@portfolio/app",
    "dev:chat-api": "pnpm --filter @portfolio/app exec next dev --webpack -- --port 3010",
    "build": "pnpm --filter @portfolio/repub-builder run build && npm run build --workspace=@portfolio/app",
    "start": "npm run start --workspace=@portfolio/app",
    "build:reader": "node scripts/prepare-reader-standalone.cjs",
    "reader": "node scripts/run-reader-standalone.cjs",
    "reader:list": "node scripts/run-reader-standalone.cjs --list",
    "build:reader:standalone": "pnpm run build:reader",
    "start:reader:standalone": "pnpm run reader",
    "serve:reader:standalone": "pnpm run build:reader && pnpm run reader",
    "dev:portfolio": "node scripts/portfolio-local.mjs dev",
    "build:portfolio": "node scripts/portfolio-local.mjs build",
    "start:portfolio:local": "node scripts/portfolio-local.mjs start",
    "lint": "npm run lint --workspace=@portfolio/app",
    "package": "./scripts/manage-packages.sh",
    "package:setup": "./scripts/manage-packages.sh setup",
    "package:token": "./scripts/manage-packages.sh token",
    "package:build": "./scripts/manage-packages.sh build",
    "package:sync": "./scripts/manage-packages.sh sync",
    "package:sync:all": "./scripts/sync-all-packages.sh",
    "package:publish": "./scripts/manage-packages.sh publish",
    "package:workflow": "./scripts/manage-packages.sh workflow",
    "package:status": "./scripts/manage-packages.sh status",
    "package:list": "./scripts/manage-packages.sh list",
    "package:tokens:all": "./scripts/setup-all-tokens.sh",
    "package:workflows:all": "./scripts/setup-all-workflows.sh",
    "package:check": "./scripts/setup-env.sh",
    "package:verify": "./scripts/verify-auth.sh",
    "package:token:check": "./scripts/check-token-setup.sh",
    "package:org:setup": "./scripts/setup-org-secrets.sh",
    "package:org:update": "./scripts/update-org-npm-token.sh",
    "build:books": "pnpm --filter @portfolio/repub-builder run build && node scripts/build-books.cjs",
    "publish:book-artifacts": "pnpm --filter @portfolio/app exec tsx --tsconfig tsconfig.json scripts/publish-book-artifacts.ts",
    "publish:public-media": "pnpm --filter @portfolio/app exec tsx --tsconfig tsconfig.json scripts/publish-public-media.ts",
    "seed:site-apps": "pnpm --filter @portfolio/app exec tsx --tsconfig tsconfig.json scripts/seed-site-app-records.ts",
    "build:books:publish": "pnpm run build:books && pnpm run publish:book-artifacts",
    "planning": "node scripts/run-planning-cli.mjs",
    "planning:init": "node scripts/run-planning-cli.mjs init --minimal --no-agents-md",
    "planning:init:force": "node scripts/run-planning-cli.mjs init --force --minimal --no-agents-md",
    "planning:init:full": "node scripts/run-planning-cli.mjs init --no-agents-md",
    "planning:init:full:force": "node scripts/run-planning-cli.mjs init --force --no-agents-md",
    "planning:snapshot": "node scripts/run-planning-cli.mjs snapshot",
    "planning:checklist": "node scripts/run-planning-cli.mjs setup checklist",
    "planning:report-view": "node scripts/run-planning-cli.mjs report view",
    "planning:ui": "node scripts/run-planning-cli.mjs report view",
    "planning:embed-packs": "node scripts/run-planning-cli.mjs pack embed-build -o apps/portfolio/public/planning-embed/builtin-packs.json --docs-dir apps/portfolio/content/docs/repo-planner",
    "vendor:grimetime:init": "git submodule update --init --recursive vendor/grime-time-site",
    "vendor:grimetime:env": "node scripts/grimetime-vendor.mjs env",
    "vendor:grimetime:env:check": "node scripts/grimetime-vendor.mjs check",
    "vendor:grimetime:install": "node scripts/grimetime-vendor.mjs install",
    "vendor:grimetime:build": "node scripts/grimetime-vendor.mjs run-script build --env NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:5466",
    "vendor:grimetime:dev": "node scripts/grimetime-vendor.mjs run-script dev --env GT_DEV_PORT=5465 --env NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:5465",
    "vendor:grimetime:start:local": "node scripts/grimetime-vendor.mjs run-script start --env NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:5466 -- --hostname 127.0.0.1 --port 5466",
    "vendor:grimetime:migrate": "node scripts/grimetime-vendor.mjs run-script payload -- migrate",
    "vendor:grimetime:bootstrap-admin": "node scripts/grimetime-vendor.mjs run-script bootstrap:admin",
    "vendor:grimetime:admin:ensure": "node scripts/grimetime-vendor.mjs run-script admin:ensure",
    "vendor:grimetime:ai:ingest": "node scripts/grimetime-vendor.mjs run-script ai:ops:ingest",
    "vendor:grimetime:seed": "node scripts/grimetime-vendor.mjs run-script seed:baseline",
    "vendor:grimetime:seed:full": "node scripts/grimetime-vendor.mjs run-script seed",
    "dev:grimetime": "pnpm run vendor:grimetime:dev",
    "build:grimetime": "pnpm run vendor:grimetime:build",
    "start:grimetime:local": "pnpm run vendor:grimetime:start:local",
    "vendors:commit-push": "node scripts/commit-push-vendors-and-root.cjs",
    "test:magicborn-cli": "pnpm --filter @magicborn/cli test",
    "test:unit": "pnpm --filter @portfolio/app run test:unit",
    "test:unit:coverage": "pnpm --filter @portfolio/app run test:unit:coverage",
    "test:unit:report": "pnpm --filter @portfolio/app run test:unit:report",
    "chat:env-preview": "pnpm --filter @portfolio/app run chat:env-preview",
    "rag:ingest": "node scripts/rag-ingest-from-root.cjs",
    "magicborn": "node packages/magicborn-cli/dist/cli.js",
    "mb": "node packages/magicborn-cli/dist/cli.js",
    "completion:pnpm-bash": "node -e \"console.log('bash: source ./completions/pnpm-workspace.bash (from repo root, after pnpm install)')\""
  },
  "devDependencies": {
    "@iarna/toml": "^2.2.5",
    "archiver": "^7.0.1",
    "commander": "^14.0.3",
    "ejs": "^5.0.1",
    "epub-gen": "^0.1.0",
    "fast-xml-parser": "^5.5.9",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "styled-jsx>react": "19.2.1",
      "next": "16.0.8",
      "@next/mdx": "16.0.8",
      "sharp": "^0.34.5"
    }
  }
}
